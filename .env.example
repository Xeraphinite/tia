# OpenRouter API key. Tiny Agent maps this to LiteLLM's OpenRouter adapter explicitly.
# Never put real credentials in this example file.
OPENAI_API_KEY=

# Optional model override. The local default is openai/gpt-5.4-nano.
TIA_MODEL=openai/gpt-5.4-nano

# Optional durable SQLite database path. The local default is tia.sqlite3.
TIA_DATABASE_PATH=tia.sqlite3

# Optional Streamlit frontend settings.
TIA_API_URL=http://127.0.0.1:8000
TIA_USER_ID=local-user
